{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "HLS Downloader",
  "version": "1.4.4",
  "identifier": "com.ciaooo55.hls-downloader",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "HLS Downloader",
        "width": 1440,
        "height": 840,
        "minWidth": 1100,
        "minHeight": 650,
        "center": true,
        "visible": false,
        "resizable": true,
        "transparent": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "icon": [
      "../../assets/app-icon.png",
      "../../assets/app-icon.ico"
    ]
  }
}
